# Shared env for docker-compose.yml
# Copy this to .env and change values before running in production.

NODE_ENV=development

# Database
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tk_clocking

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET=tk_clocking_dev_secret_256bit_key_change_me
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=tk_clocking_refresh_dev_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

# CORS (Next.js dashboard URL)
CORS_ORIGIN=http://localhost:3001
